---
import Navbar from "../components/page/Navbar";
import Footer from "../components/page/Footer.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Ronal LLM</title>
  </head>
  <body class="font-normal">
    <Navbar client:only="react" />
    <slot />
    <Footer />
  </body>
</html>

<style>
  /* quicksand-latin-wght-normal */
  @font-face {
    font-family: "Quicksand Variable";
    font-style: normal;
    font-display: swap;
    font-weight: 300 700;
    src: url(@fontsource-variable/quicksand/files/quicksand-latin-wght-normal.woff2)
      format("woff2-variations");
    unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA,
      U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+2074, U+20AC, U+2122,
      U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
  }

  body {
    font-family: "Quicksand Variable", sans-serif;
  }
</style>
